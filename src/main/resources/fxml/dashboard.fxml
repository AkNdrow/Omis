<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.omis.controller.DashboardController"
            prefWidth="1024" prefHeight="768">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="0">
            <padding><Insets top="20" bottom="20"/></padding>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="2">
                <padding><Insets bottom="20" left="15" right="15"/></padding>
                <Label text="OMIS" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Papelería Omis" style="-fx-font-size: 12px; -fx-text-fill: #90CAF9;"/>
            </VBox>

            <Separator style="-fx-border-color: rgba(255,255,255,0.1);"/>

            <!-- Info de usuario -->
            <VBox fx:id="userInfoBox" spacing="2">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>
                <Label fx:id="lblNombreUsuario" text="Usuario"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Label fx:id="lblRolUsuario" text="Rol"
                       style="-fx-text-fill: #90CAF9; -fx-font-size: 12px;"/>
            </VBox>

            <Separator style="-fx-border-color: rgba(255,255,255,0.1);"/>

            <!-- Menú de navegación -->
            <VBox spacing="2">
                <padding><Insets top="10"/></padding>
                <Button text="📊  Panel de Control" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavInicio"/>
                <Button fx:id="btnNavInventario" text="📦  Inventario" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavInventario"/>
                <Button fx:id="btnNavEntradas" text="📥  Entradas" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavEntradas"/>
                <Button fx:id="btnNavPuntoVenta" text="🛒  Punto de Venta" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavPuntoVenta"/>
                <Button fx:id="btnNavUsuarios" text="👥  Usuarios" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavUsuarios"/>
                <Button fx:id="btnNavCatalogos" text="📋  Catálogos" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavCatalogos"/>
                <Button text="📄  Reportes" styleClass="sidebar-button" maxWidth="Infinity"
                        onAction="#handleNavReportes"/>
            </VBox>

            <!-- Espaciador -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Cerrar sesión -->
            <VBox>
                <padding><Insets left="10" right="10" bottom="5"/></padding>
                <Button text="🚪  Cerrar Sesión" onAction="#handleCerrarSesion"
                        styleClass="sidebar-button" maxWidth="Infinity"
                        style="-fx-text-fill: #EF9A9A;"/>
            </VBox>
        </VBox>
    </left>

    <!-- Contenido principal dinámico -->
    <center>
        <StackPane fx:id="contentPane">
            <!-- Vista de inicio por defecto -->
            <VBox alignment="CENTER" spacing="16">
                <padding><Insets top="40" left="40" right="40" bottom="40"/></padding>
                <Label text="Panel de Control" styleClass="label-title"/>
                <Label text="Bienvenido al sistema OMIS" styleClass="label-subtitle"/>
                <Separator/>
                <Label fx:id="lblBienvenida" text=""
                       style="-fx-font-size: 16px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>

                <HBox spacing="20" alignment="CENTER" AnchorPane.topAnchor="20">
                    <padding><Insets top="30"/></padding>
                    <VBox styleClass="card" alignment="CENTER" prefWidth="250" prefHeight="150" spacing="10">
                        <Label text="Ventas de Hoy" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblVentasHoy" text="\$0.00" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                    </VBox>
                    <VBox styleClass="card" alignment="CENTER" prefWidth="250" prefHeight="150" spacing="10">
                        <Label text="Productos Bajo Stock" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblBajoStock" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f44336;"/>
                    </VBox>
                    <VBox styleClass="card" alignment="CENTER" prefWidth="250" prefHeight="150" spacing="10">
                        <Label text="Empleados Activos" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                        <Label fx:id="lblTotalUsuarios" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    </VBox>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>
                <Label text="Seleccione un módulo del menú lateral para comenzar."
                       styleClass="label-subtitle" wrapText="true" maxWidth="500"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
